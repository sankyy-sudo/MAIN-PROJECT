{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "moduleResolution": "Node16",

    "resolveJsonModule": true
  },

  "include": ["src"],

  "exclude": ["node_modules"]
}

